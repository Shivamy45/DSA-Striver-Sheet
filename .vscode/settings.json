{
	"github.copilot.enable": {
		"*": false,
		"plaintext": false,
		"markdown": true,
		"scminput": false,
		"cpp": false
	},
	"files.associations": {
		"iostream": "cpp",
		"__tree": "cpp",
		"bitset": "cpp",
		"set": "cpp",
		"vector": "cpp",
		"unordered_map": "cpp",
		"complex": "cpp",
		"string": "cpp",
		"new": "cpp",
		"stack": "cpp",
		"__config": "cpp",
		"unordered_set": "cpp"
	},
	"json.schemas": [],
	"[cpp]": {
		"editor.defaultFormatter": "ms-vscode.cpptools",

		"editor.formatOnSave": true,

		"editor.tabSize": 4,

		"editor.insertSpaces": true
	},

	"C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 4, TabWidth: 4, UseTab: Never, BreakBeforeBraces: Attach }"
}
